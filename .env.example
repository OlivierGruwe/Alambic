# ═══════════════════════════════════════════════════════════════════════════════
# Alambic — variables d'environnement (développement local)
# ═══════════════════════════════════════════════════════════════════════════════
# Copie ce fichier en .env (make env) et adapte si besoin.
# En PRODUCTION : ne JAMAIS committer le .env ; utiliser des Docker secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Ces 3 valeurs initialisent le conteneur Postgres ET doivent correspondre à
# ALAMBIC_DATABASE_URL ci-dessous. C'est l'incohérence entre les deux qui
# provoque le "password authentication failed".
POSTGRES_USER=alambic
POSTGRES_PASSWORD=alambic_dev_pwd
POSTGRES_DB=alambic
POSTGRES_PORT=5432

# URL complète consommée par alambic_core (SQLAlchemy + psycopg v3).
# Hôte = 'postgres' (nom du service) quand on tourne DANS Docker,
#        'localhost' quand on lance les tests depuis Windows.
ALAMBIC_DATABASE_URL=postgresql+psycopg://alambic:alambic_dev_pwd@localhost:5432/alambic

# ── Chiffrement des secrets (Fernet) ─────────────────────────────────────────
# OBLIGATOIRE. Génère une clé :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Plusieurs clés séparées par des virgules = rotation (la 1re chiffre).
ALAMBIC_SECRET_KEY=

# ── RabbitMQ (broker Celery) ─────────────────────────────────────────────────
RABBITMQ_USER=alambic
RABBITMQ_PASSWORD=alambic_dev_pwd
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── Redis (backend de résultats Celery) ──────────────────────────────────────
REDIS_PORT=6379

# ── Garage (stockage objet S3-compatible, souverain — remplace S3) ───────────
# Garage par Deuxfleurs (association FR), écrit en Rust.
GARAGE_S3_PORT=3900
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903

# Nom de la clé applicative créée par garage-init (accès limité aux 3 buckets).
ALAMBIC_S3_KEY_NAME=alambic-app

# Identifiants S3 de l'appli — À RENSEIGNER après 'make up' avec :
#   docker compose exec garage garage key info alambic-app --show-secret
ALAMBIC_S3_ENDPOINT=http://localhost:3900
ALAMBIC_S3_REGION=garage
ALAMBIC_S3_ACCESS_KEY=
ALAMBIC_S3_SECRET_KEY=

# Buckets applicatifs (créés par garage-init) — séparation input/work/storage
MINIO_BUCKET_INPUT=alambic-input
MINIO_BUCKET_WORK=alambic-work
MINIO_BUCKET_STORAGE=alambic-storage
