# ═══════════════════════════════════════════════════════════════════════════════
# Alambic — variables d'environnement (développement local)
# ═══════════════════════════════════════════════════════════════════════════════
# Copie ce fichier en .env (make env) et adapte si besoin.
# En PRODUCTION : ne JAMAIS committer le .env ; utiliser des Docker secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Ces 3 valeurs initialisent le conteneur Postgres ET doivent correspondre à
# ALAMBIC_DATABASE_URL ci-dessous. C'est l'incohérence entre les deux qui
# provoque le "password authentication failed".
POSTGRES_USER=alambic
POSTGRES_PASSWORD=alambic_dev_pwd
POSTGRES_DB=alambic
POSTGRES_PORT=5432

# URL complète consommée par alambic_core (SQLAlchemy + psycopg v3).
# Hôte = 'postgres' (nom du service) quand on tourne DANS Docker,
#        'localhost' quand on lance les tests depuis Windows.
ALAMBIC_DATABASE_URL=postgresql+psycopg://alambic:alambic_dev_pwd@localhost:5432/alambic

# ── Chiffrement des secrets (Fernet) ─────────────────────────────────────────
# OBLIGATOIRE. Génère une clé :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Plusieurs clés séparées par des virgules = rotation (la 1re chiffre).
ALAMBIC_SECRET_KEY=

# ── RabbitMQ (broker Celery) ─────────────────────────────────────────────────
RABBITMQ_USER=alambic
RABBITMQ_PASSWORD=alambic_dev_pwd
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── Redis (backend de résultats Celery) ──────────────────────────────────────
REDIS_PORT=6379
# ── Celery (broker + backend de résultats) ───────────────────────────────────
# Hôte = 'rabbitmq'/'redis' (noms de services) quand on tourne DANS Docker,
#        'localhost' quand on lance worker/poller depuis Windows (hors Docker).
CELERY_BROKER=amqp://alambic:alambic_dev_pwd@localhost:5672//
CELERY_BACKEND=redis://localhost:6379/0

# ── Garage (stockage objet S3-compatible, souverain — remplace S3) ───────────
# Garage par Deuxfleurs (association FR), écrit en Rust.
GARAGE_S3_PORT=3900
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903

# Nom de la clé applicative créée par garage-init (accès limité aux 3 buckets).
ALAMBIC_S3_KEY_NAME=alambic-app

# Identifiants S3 de l'appli — À RENSEIGNER après 'make up' avec :
#   docker compose exec garage garage key info alambic-app --show-secret
ALAMBIC_S3_ENDPOINT=http://localhost:3900
ALAMBIC_S3_REGION=garage
ALAMBIC_S3_ACCESS_KEY=
ALAMBIC_S3_SECRET_KEY=

# Buckets applicatifs (créés par garage-init) — séparation input/work/storage
# Noms lus par le code (alambic_core.storage, start_ingestion, poller).
ALAMBIC_S3_INPUT_BUCKET=alambic-input
ALAMBIC_S3_WORK_BUCKET=alambic-work
ALAMBIC_S3_STORAGE_BUCKET=alambic-storage

# ── Rétention des transactions exportées ─────────────────────────────────────
# Délai (jours) avant purge automatique d'une transaction exportée : fichiers
# work Garage + ligne en base (backup conservé). Surchargeable PAR CONFIG via
# general.retention_days. Purge balayée quotidiennement par Celery Beat (make beat).
ALAMBIC_RETENTION_DAYS=30

# ── Déploiement Docker : effectifs par étape (scalabilité horizontale) ────────
# Nombre de workers (répliques) par queue. Régler selon la charge : l'OCR est
# le goulot coûteux, on en met plusieurs ; le CAB est léger, un seul suffit.
# Après modification : make up-all (ou docker compose ... up -d).
NORMAL_REPLICAS=1
OFFICE_REPLICAS=1
CAB_REPLICAS=1
OCR_REPLICAS=2
MULTIDOC_REPLICAS=1
# Seuil mémoire (Ko) avant recyclage du worker multidoc (rendu d'images).
MULTIDOC_MAX_MEM_KB=1500000
CLASSIF_REPLICAS=1
EXTRACT_REPLICAS=1
POLLER_INTERVAL=5

# ── Exposition HTTPS (reverse proxy Caddy devant l'UI/WS) ────────────────────
# L'UI n'est plus exposée en direct : tout passe par Caddy en HTTPS.
# ALAMBIC_DOMAIN=localhost → certificat interne auto-signé (souverain, défaut).
# Pour un domaine public + Let's Encrypt : mettre le vrai domaine + l'email,
# puis adapter la directive tls dans caddy/Caddyfile (voir commentaires).
ALAMBIC_DOMAIN=localhost
ALAMBIC_TLS_EMAIL=
HTTPS_PORT=443
HTTP_PORT=80

# NB : EN DOCKER, les hôtes sont les NOMS DE SERVICES (postgres, rabbitmq, redis,
# garage), PAS localhost. Le compose applicatif fournit déjà ces valeurs par
# défaut. Les variables CELERY_BROKER/ALAMBIC_DATABASE_URL/ALAMBIC_S3_ENDPOINT
# ci-dessus (en localhost) ne servent QUE pour lancer worker/poller/ui EN LOCAL
# (hors Docker). En Docker, le compose les surcharge vers les noms de services.

# ── Embedding local (TEI / BGE-M3) ─────────────────────────────────────────
# Modèle d'embedding servi par le conteneur 'embeddings' (TEI, CPU).
# BAAI/bge-m3 : multilingue (FR), licence MIT, ~4-8 Go RAM.
EMBEDDING_MODEL_ID=BAAI/bge-m3
# Port hôte exposé pour debug (l'usage interne se fait via le réseau Docker).
EMBEDDING_PORT=8085
# URL interne consommée par les workers (définie dans .env.docker en Docker).
# Vide = embedding désactivé (classification lexical → LLM).
EMBEDDING_LOCAL_URL=
EMBEDDING_LOCAL_MODEL=bge-m3
